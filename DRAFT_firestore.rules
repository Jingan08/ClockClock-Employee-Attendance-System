rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Owner checks
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role detection via relational secure document lookups
    function getAdminData(userId) {
      return get(/databases/$(database)/documents/admins/$(userId)).data;
    }

    function getEmployeeData(userId) {
      return get(/databases/$(database)/documents/employees/$(userId)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && getAdminData(request.auth.uid).role == 'admin') || 
        (request.auth.token != null && 'email' in request.auth.token && request.auth.token.email == 'admin@attendance.com')
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && getAdminData(request.auth.uid).role == 'superadmin') || 
        (request.auth.token != null && 'email' in request.auth.token && request.auth.token.email == 'superadmin@attendance.com')
      );
    }

    function isEmployee() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/employees/$(request.auth.uid)) && getEmployeeData(request.auth.uid).role == 'employee') || 
        (request.auth.token != null && 'email' in request.auth.token && (request.auth.token.email == 'employee@attendance.com' || request.auth.token.email == 'john@attendance.com'))
      );
    }

    // 2a. Profile Management Collection Rules (Admins)
    match /admins/{adminId} {
      allow get: if isOwner(adminId) || isAdmin() || isSuperAdmin();
      allow list: if isAdmin() || isSuperAdmin();
      
      allow create: if isSignedIn() && isValidId(adminId) && (
        (isSuperAdmin() && incoming().role == 'admin') ||
        (isOwner(adminId) && incoming().email == 'superadmin@attendance.com' && incoming().role == 'superadmin') ||
        (isOwner(adminId) && incoming().email == 'admin@attendance.com' && incoming().role == 'admin')
      );

      allow update: if isSignedIn() && isValidId(adminId) && (
        (isOwner(adminId) && incoming().userID == existing().userID && incoming().role == existing().role && incoming().status == existing().status && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'passwordHash'])) ||
        (isSuperAdmin() && incoming().userID == existing().userID)
      );

      allow delete: if isSuperAdmin();
    }

    // 2b. Profile Management Collection Rules (Employees)
    match /employees/{employeeId} {
      allow get: if isOwner(employeeId) || isAdmin() || isSuperAdmin();
      allow list: if isAdmin() || isSuperAdmin();

      allow create: if isSignedIn() && isValidId(employeeId) && (
        (isOwner(employeeId) && incoming().userID == employeeId && incoming().role == 'employee' && incoming().status == 'active') ||
        (isSuperAdmin() && incoming().role == 'employee') ||
        (isAdmin() && incoming().role == 'employee')
      );

      allow update: if isSignedIn() && isValidId(employeeId) && (
        (isOwner(employeeId) && incoming().userID == existing().userID && incoming().role == existing().role && incoming().status == existing().status && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'passwordHash'])) ||
        (isSuperAdmin() && incoming().userID == existing().userID) ||
        (isAdmin() && existing().role == 'employee' && incoming().userID == existing().userID && incoming().role == 'employee')
      );

      allow delete: if isSuperAdmin();
    }

    // 3. Shift Transition Collection Rules (Attendance)
    match /attendances/{attendanceId} {
      allow get: if isSignedIn() && (resource.data.employeeID == request.auth.uid || isAdmin() || isSuperAdmin());
      allow list: if isSignedIn() && (resource.data.employeeID == request.auth.uid || isAdmin() || isSuperAdmin());

      // Punching the clock (Check-In)
      allow create: if isEmployee() && isValidId(attendanceId) && (
        incoming().employeeID == request.auth.uid &&
        incoming().checkInTime is string && incoming().checkInTime.size() > 0 &&
        incoming().status == 'checked-in' &&
        incoming().date is string && incoming().date.size() == 10
      );

      // Logging Out of shifting (Check-Out) or Admin management adjustments
      allow update: if isSignedIn() && isValidId(attendanceId) && (
        // Self-Check-Out transition
        (resource.data.employeeID == request.auth.uid && 
         incoming().employeeID == existing().employeeID &&
         incoming().date == existing().date &&
         incoming().checkInTime == existing().checkInTime &&
         incoming().checkOutTime is string && incoming().checkOutTime.size() > 0 &&
         incoming().status == 'checked-out' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['checkOutTime', 'status'])) ||
         
        // Admin manual override and clock-in correction
        (isAdmin() && incoming().employeeID == existing().employeeID) ||
        (isSuperAdmin())
      );

      allow delete: if isAdmin() || isSuperAdmin();
    }

    // 4. Time-Sensitive Security Token Collection Rules (QRToken)
    match /qrtokens/{tokenId} {
      // Employees must read available configurations to scan and validate
      allow read: if isSignedIn();

      // Only administrators can generate the active key
      allow create: if (isAdmin() || isSuperAdmin()) && isValidId(tokenId) && (
        incoming().createdTime is string && incoming().createdTime.size() > 0 &&
        incoming().expiryTime is string && incoming().expiryTime.size() > 0
      );

      allow update, delete: if (isAdmin() || isSuperAdmin());
    }
  }
}
